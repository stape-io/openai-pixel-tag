setup: |-
  const JSON = require('JSON');
  const Object = require('Object');
  const getType = require('getType');

  const assign = (target, source) => {
    if (!source) return target;
    Object.keys(source).forEach((key) => { target[key] = source[key]; });
    return target;
  };

  // Mock oaiq queue — captures all calls made to the pixel queue
  let queueCalls = [];
  const mockQueue = function() {
    const args = [];
    for (let i = 0; i < arguments.length; i++) {
      args.push(arguments[i]);
    }
    queueCalls.push(args);
  };
  mockQueue.q = [];

  let injectScriptCalls = [];
  mock('injectScript', (url, onsuccess, onfailure, cacheToken) => {
    injectScriptCalls.push({ url: url, onsuccess: onsuccess, onfailure: onfailure, cacheToken: cacheToken });
    onsuccess();
  });

  mock('copyFromWindow', (key) => {
    if (key === 'oaiq') return mockQueue;
    return undefined;
  });

  mock('createArgumentsQueue', (name, queueName) => {
    return mockQueue;
  });

  let createQueueItems = [];
  mock('createQueue', (name) => {
    return (item) => { createQueueItems.push([name, item]); };
  });

  mock('copyFromDataLayer', () => undefined);
  mock('isConsentGranted', () => true);
  mock('addConsentListener', () => {});

  let templateStorageData = {};
  mockObject('templateStorage', {
    getItem: (key) => templateStorageData[key],
    setItem: (key, value) => { templateStorageData[key] = value; }
  });

  let localStorageData = {};
  mockObject('localStorage', {
    getItem: (key) => localStorageData[key],
    setItem: (key, value) => { localStorageData[key] = value; }
  });

  mock('makeTableMap', (table, keyName, valueName) => {
    const result = {};
    table.forEach((row) => { result[row[keyName]] = row[valueName]; });
    return result;
  });

  mock('sha256', (input, successCb, errorCb, options) => {
    successCb('hashed_' + input);
  });

  const mockData = {
    pixelId: 'PIXEL123',
    consentGranted: true,
    enableGoogleConsentMode: false,
    eventNameSetupMethod: 'override',
    eventName: 'standard',
    eventNameStandard: 'page_viewed',
    enableDataLayerMapping: false,
    enableAdvancedMatching: false,
    enableEventUserDataEnhancement: false,
    storeUserDataHashed: false,
    pushEventIdToDataLayer: false,
    enableMostRecentDataLayerEventOnly: false,
    debugEnabled: false,
    userDataFromVariable: false
  };


